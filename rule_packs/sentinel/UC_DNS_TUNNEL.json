{
  "schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "apiVersion": "2022-12-01-preview",
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/UC_DNS_TUNNEL')]",
      "kind": "Scheduled",
      "properties": {
        "displayName": "DNS tunneling / TXT-heavy domain queries",
        "description": "Long subdomain labels + frequent queries to a single 2LD = DNS C2/exfil.",
        "severity": "Low",
        "enabled": false,
        "query": "// ASIM ImDnsActivity normalises Windows DNS, Sysmon EID 22, Linux dnsmasq, etc.\nImDnsActivity\n| where TimeGenerated > ago(24h)\n| where DnsQueryTypeName == \"TXT\"\n| summarize Queries = count(), DistinctNames = dcount(DnsQuery)\n            by SrcIpAddr, bin(TimeGenerated, 5m)\n| where Queries > 200    // tune to TXT-query baseline for environment\n| order by Queries desc\n",
        "queryFrequency": "PT1D",
        "queryPeriod": "PT24H",
        "triggerOperator": "GreaterThan",
        "triggerThreshold": 0,
        "tactics": [],
        "techniques": [
          "T1071.004",
          "T1048.003"
        ],
        "alertRuleTemplateName": "UC_DNS_TUNNEL",
        "customDetails": {
          "tier": "hunting",
          "fp_rate_estimate": "medium",
          "source_url": "https://github.com/Virtualhaggis/usecaseintel/blob/main/use_cases/c2/UC_DNS_TUNNEL.yml"
        }
      }
    }
  ],
  "parameters": {
    "workspaceName": {
      "type": "string"
    }
  }
}