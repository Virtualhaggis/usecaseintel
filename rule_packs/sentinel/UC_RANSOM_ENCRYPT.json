{
  "schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "apiVersion": "2022-12-01-preview",
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/UC_RANSOM_ENCRYPT')]",
      "kind": "Scheduled",
      "properties": {
        "displayName": "Ransomware-style mass file rename / extension change",
        "description": "Threshold detection: many files renamed in short window, often with new extension.",
        "severity": "High",
        "enabled": false,
        "query": "DeviceFileEvents\n| where Timestamp > ago(1d)\n| where ActionType in (\"FileRenamed\",\"FileModified\")\n| summarize files = dcount(FileName) by DeviceName, AccountName, bin(Timestamp, 1m)\n| where files > 200\n| order by files desc",
        "queryFrequency": "PT1H",
        "queryPeriod": "PT24H",
        "triggerOperator": "GreaterThan",
        "triggerThreshold": 0,
        "tactics": [],
        "techniques": [
          "T1486"
        ],
        "alertRuleTemplateName": "UC_RANSOM_ENCRYPT",
        "customDetails": {
          "tier": "alerting",
          "fp_rate_estimate": "unknown",
          "source_url": "https://github.com/Virtualhaggis/usecaseintel/blob/main/use_cases/actions/UC_RANSOM_ENCRYPT.yml"
        }
      }
    }
  ],
  "parameters": {
    "workspaceName": {
      "type": "string"
    }
  }
}