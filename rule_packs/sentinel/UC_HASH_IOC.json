{
  "schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "apiVersion": "2022-12-01-preview",
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/UC_HASH_IOC')]",
      "kind": "Scheduled",
      "properties": {
        "displayName": "File hash IOCs \u2014 endpoint file/process match",
        "description": "Match SHA256/SHA1/MD5 named in the article against EDR file/process telemetry.",
        "severity": "High",
        "enabled": false,
        "query": "union DeviceFileEvents, DeviceProcessEvents\n| where Timestamp > ago(7d)\n| where SHA256 in~ (__HASH_LIST__) or SHA1 in~ (__HASH_LIST__) or MD5 in~ (__HASH_LIST__)\n| project Timestamp, DeviceName, ActionType, FileName, FolderPath, SHA256, ProcessCommandLine",
        "queryFrequency": "PT1H",
        "queryPeriod": "PT24H",
        "triggerOperator": "GreaterThan",
        "triggerThreshold": 0,
        "tactics": [],
        "techniques": [
          "T1027"
        ],
        "alertRuleTemplateName": "UC_HASH_IOC",
        "customDetails": {
          "tier": "alerting",
          "fp_rate_estimate": "low",
          "source_url": "https://github.com/Virtualhaggis/usecaseintel/blob/main/use_cases/install/UC_HASH_IOC.yml"
        }
      }
    }
  ],
  "parameters": {
    "workspaceName": {
      "type": "string"
    }
  }
}