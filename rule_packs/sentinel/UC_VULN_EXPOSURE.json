{
  "schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "apiVersion": "2022-12-01-preview",
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/UC_VULN_EXPOSURE')]",
      "kind": "Scheduled",
      "properties": {
        "displayName": "Asset exposure \u2014 vulnerability matches article CVE(s)",
        "description": "Match vulnerability scanner output to the CVE(s) named in the article.",
        "severity": "High",
        "enabled": false,
        "query": "DeviceTvmSoftwareVulnerabilities\n| where CveId in~ (__CVE_LIST__)\n| join kind=inner DeviceInfo on DeviceId\n| project DeviceName, OSPlatform, CveId, VulnerabilitySeverityLevel, RecommendedSecurityUpdate",
        "queryFrequency": "PT1H",
        "queryPeriod": "PT24H",
        "triggerOperator": "GreaterThan",
        "triggerThreshold": 0,
        "tactics": [],
        "techniques": [
          "T1190"
        ],
        "alertRuleTemplateName": "UC_VULN_EXPOSURE",
        "customDetails": {
          "tier": "alerting",
          "fp_rate_estimate": "unknown",
          "source_url": "https://github.com/Virtualhaggis/usecaseintel/blob/main/use_cases/recon/UC_VULN_EXPOSURE.yml"
        }
      }
    }
  ],
  "parameters": {
    "workspaceName": {
      "type": "string"
    }
  }
}