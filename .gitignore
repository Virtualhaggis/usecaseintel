# Generated artefacts (regenerated locally; index.html IS committed
# because it IS the published Pages site — Pages serves files from
# the main branch root and there is no CI step that rebuilds + commits
# it post-push, so excluding it leaves Pages serving a 404).
daily_digest.md
data_sources/registry.json
data_sources/sync_log.json
data_sources/last_run.json
data_sources/validation_report.json
logs/
__pycache__/
*.pyc

# NOTE: intel/, catalog/, and briefings/ ARE committed — they are the public
# threat-intel exports, catalog snapshots, and per-article briefings that
# consumers (SIEMs, scripts, TIPs, analysts) pull from raw URLs on GitHub.
# They get refreshed each time generate.py runs.

# Article-body fetch cache (re-fetched on demand; never committed)
intel/.article_cache/

# IOC enrichment cache (ThreatFox / URLhaus lookups, never committed)
intel/.enrich_cache/

# LLM-generated UC cache (per-article API responses, never committed)
intel/.llm_uc_cache/

# Local-only files
*.bak_*
inspect_*.py
_check_*.py
_audit_*.py
_migrate_to_yaml.py

# Cache backup files left behind by invalidate_problem_uc_cache.py.
# The originals get renamed with a timestamp suffix; keep them locally
# as a recovery option but don't pollute git status with them.
*.invalidated-*
